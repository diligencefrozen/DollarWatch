<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jeesung.dollarwatch.member.MemberMapper">
    <insert id="join" parameterType="com.jeesung.dollarwatch.member.Member">
        insert into dollar_member (
            m_id,
            m_pw,
            m_name,
            m_email,
            m_reg_date
        ) values (
            #{m_id},
            #{m_pw},
            #{m_name},
            #{m_email},
            sysdate
        )
    </insert>

    <select id="login" parameterType="com.jeesung.dollarwatch.member.Member" resultType="com.jeesung.dollarwatch.member.Member">
        select *
        from dollar_member
        where m_id = #{m_id}
        and m_pw = #{m_pw}
    </select>

    <select id="getMemberById" parameterType="String" resultType="com.jeesung.dollarwatch.member.Member">
        select *
        from dollar_member
        where m_id = #{value}
    </select>
</mapper>
